# =============================================================================
# ASM Asset Management System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
POSTGRES_USER=asm_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=asm_database
DATABASE_URL=postgresql+asyncpg://asm_user:CHANGE_ME_IN_PRODUCTION@db:5432/asm_database
DATABASE_URL_SYNC=postgresql+psycopg2://asm_user:CHANGE_ME_IN_PRODUCTION@db:5432/asm_database

# JWT Authentication
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_MINIMUM_32_CHARACTERS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application
APP_NAME=ASM Asset Management System
APP_VERSION=1.0.0
DEBUG=false

# Lifecycle Management
STALE_THRESHOLD_DAYS=30

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]
